{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@dowgnut/*": ["packages/*/src"],
      "@dowgnut/ui": ["packages/ui/src"],
      "@dowgnut/config": ["packages/config/src"],
      "@dowgnut/types": ["packages/types/src"],
      "@dowgnut/utils": ["packages/utils/src"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".next", ".turbo"],
  "references": [
    { "path": "./packages/ui" },
    { "path": "./packages/config" },
    { "path": "./packages/types" },
    { "path": "./packages/utils" },
    { "path": "./apps/web" },
    { "path": "./apps/admin" },
    { "path": "./apps/api" }
  ]
}