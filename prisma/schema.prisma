// DowgNut — Prisma schema for advanced donut e-commerce
// SQLite datasource (ephemeral /tmp on Vercel) (Vercel Postgres / Neon / Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Catalog ────────────────────────────────────────────────
model Donut {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  price       Float
  type        String   // classic | sprinkled | stuffed | specialty
  imgUrl      String
  tags        String   @default("") // comma-separated e.g. "chocolate,glazed"
  rating      Float    @default(4.5)
  calories    Int      @default(250)
  sugar       Int      @default(10) // grams
  fat         Int      @default(8)  // grams
  stock       Int      @default(50)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  favorites   Favorite[]
  orderItems  OrderItem[]
  reviews     Review[]
}

// ── Cart (single anonymous shopper per session) ────────────
model CartItem {
  id        String   @id @default(cuid())
  sessionId String
  donutId   String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  donut Donut @relation(fields: [donutId], references: [id], onDelete: Cascade)

  @@unique([sessionId, donutId])
}

// ── Favorites / Wishlist ───────────────────────────────────
model Favorite {
  id        String   @id @default(cuid())
  sessionId String
  donutId   String
  createdAt DateTime @default(now())

  donut Donut @relation(fields: [donutId], references: [id], onDelete: Cascade)

  @@unique([sessionId, donutId])
}

// ── Orders ─────────────────────────────────────────────────
// `userId` (optional) links an order to a registered User when the customer
// is signed in. Anonymous guest orders keep `userId = null`.
model Order {
  id            String   @id @default(cuid())
  sessionId     String
  userId        String?
  customerName  String
  customerEmail String
  address       String
  city          String
  zip           String
  notes         String   @default("")
  subtotal      Float
  delivery      Float    @default(3.99)
  total         Float
  status        String   @default("preparing") // preparing | baking | out_for_delivery | delivered
  etaMinutes    Int      @default(25)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]
}

// ── Users (authentication) ──────────────────────────────────
// Backs the NextAuth Credentials provider. `passwordHash` is a scrypt-derived
// hash (`<salt>:<params>:<hash>`, base64) — see src/lib/auth-password.ts.
enum Role {
  admin
  customer
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(customer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  donutId   String
  name      String // snapshot
  price     Float  // snapshot
  imgUrl    String // snapshot
  quantity  Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  donut Donut @relation(fields: [donutId], references: [id], onDelete: Restrict)
}

// ── Reviews ────────────────────────────────────────────────
model Review {
  id        String   @id @default(cuid())
  donutId   String
  sessionId String
  author    String
  rating    Int // 1-5
  comment   String
  createdAt DateTime @default(now())

  donut Donut @relation(fields: [donutId], references: [id], onDelete: Cascade)
}
