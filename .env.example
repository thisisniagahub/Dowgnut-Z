# ── DowgNut-Z environment variables ──────────────────────────
# Copy to `.env` for local dev. On Vercel, set these in Project Settings → Environment Variables.

# Database (SQLite for local, PostgreSQL for production)
DATABASE_URL="file:./db/custom.db"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# SenangPay Payment Gateway
SENANGPAY_MERCHANT_ID="your-merchant-id"
SENANGPAY_SECRET_KEY="your-secret-key"
SENANGPAY_VERIFY_KEY="your-verify-key"
SENANGPAY_SANDBOX="true"

# Hermes Agent API Server
HERMES_API_URL="http://127.0.0.1:8642/v1"
HERMES_API_KEY="change-me-local-dev"
HERMES_MODEL="hermes-agent"

# Optional: For image optimization
NEXT_PUBLIC_IMAGE_DOMAIN="localhost"

# Optional: Feature flags
ENABLE_PWA="true"
ENABLE_ANALYTICS="false"