# ── DowgNut environment variables ──────────────────────────
# Copy to `.env` for local dev. On Vercel, set these in Project Settings → Environment Variables.

# SQLite database path (local dev).
# Local: file:/home/z/my-project/db/custom.db  (or file:./db/custom.db)
# Vercel: auto-overridden to file:/tmp/dowgnut.db by src/lib/db.ts — no need to set.
DATABASE_URL=file:./db/custom.db

# ── For persistent production storage (recommended) ────────
# Switch prisma/schema.prisma provider to "postgresql", then set:
# DATABASE_URL=postgresql://user:pass@host:5432/db?schema=public
# Run: bun run db:push && bun run seed   (once, against the Postgres DB)
